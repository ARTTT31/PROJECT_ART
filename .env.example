# Backend .env
APP_NAME="ART Workspace API"
APP_VERSION="1.0.0"
DEBUG=True

DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/art_workspace

SECRET_KEY="replace_with_a_long_random_secret"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=True
COOKIE_SAMESITE=none
AUTO_CREATE_TABLES=False

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

BACKEND_MICROSOFT_TENANT_ID="common"
BACKEND_MICROSOFT_CLIENT_ID="xxxx-xxxx-xxxx"
BACKEND_MICROSOFT_CLIENT_SECRET="xxxx"
BACKEND_MICROSOFT_REDIRECT="http://localhost:8000/api/v1/auth/microsoft/callback"
SHAREPOINT_LIST_URL="https://absscoth-my.sharepoint.com/personal/pornchai_abss_co_th/Lists/Technical%20Support%20and%20IMACD%20Booking%20Schedule/AllItems.aspx"
FRONTEND_URL="http://localhost:3000"

# Frontend .env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=xxxx-xxxx-xxxx
