# Backend
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
DATABASE_URL=postgresql://art_user:art_password_dev@localhost:5432/art_workspace

# Google OAuth (get from Google Cloud Console)
# https://console.cloud.google.com/
# Do NOT commit the actual secret - use .env.local for development
BACKEND_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
BACKEND_GOOGLE_CLIENT_SECRET=your-client-secret-here
BACKEND_GOOGLE_REDIRECT=http://localhost:8000/api/v1/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database (for docker-compose)
POSTGRES_USER=art_user
POSTGRES_PASSWORD=art_password_dev
POSTGRES_DB=art_workspace
