# Database
DATABASE_URL=postgresql://art_user:art_password_dev@localhost:5432/art_workspace

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
AUTO_CREATE_TABLES=True

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Application
APP_NAME=ART Workspace API
APP_VERSION=1.0.0
DEBUG=True
